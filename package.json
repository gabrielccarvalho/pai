{
  "name": "pai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:app": "pnpm --filter web build && pnpm --filter @workspace/desktop build",
    "dev:web": "pnpm --filter web dev",
    "build:docker": "docker compose up -d --build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tailwindcss-motion": "^1.1.1"
  }
}
