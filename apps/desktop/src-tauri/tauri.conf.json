{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pai",
  "version": "0.1.0",
  "identifier": "com.pai.desktop",
  "build": {
    "beforeDevCommand": "until curl -s http://localhost:3000 > /dev/null; do sleep 0.5; done",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": [
        {
          "schemes": ["pai"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../server-bundle": "server"
    }
  }
}
